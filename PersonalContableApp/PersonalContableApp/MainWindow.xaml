<!-- Archivo: MainWindow.xaml -->
<Window x:Class="PersonalContableApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PersonalContableApp"
        Title="Gestión de Personal Contable" Height="750" Width="900">
    <Grid Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Título dinámico según modo -->
                <TextBlock x:Name="txtTituloFormulario"
                           Text="Agregar Nuevo Personal"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20" />

                <!-- Formulario -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Apellido y Nombre:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtApellidoNombre" Grid.Row="0" Grid.Column="1" Margin="5" MaxLength="50"/>

                    <Label Content="Domicilio:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtDomicilio" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <Label Content="Localidad:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtLocalidad" Grid.Row="2" Grid.Column="1" Margin="5"/>

                    <Label Content="Provincia:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtProvincia" Grid.Row="3" Grid.Column="1" Margin="5"/>

                    <Label Content="Código Postal:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtCodigoPostal" Grid.Row="4" Grid.Column="1" Margin="5"/>

                    <Label Content="Puesto:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbPuesto" Grid.Row="5" Grid.Column="1" Margin="5">
                        <ComboBoxItem Content="1 - Contable" Tag="1"/>
                        <ComboBoxItem Content="2 - Taller" Tag="2"/>
                        <ComboBoxItem Content="3 - Recursos Humanos" Tag="3"/>
                        <ComboBoxItem Content="4 - IT" Tag="4"/>
                        <ComboBoxItem Content="5 - Marketing" Tag="5"/>
                    </ComboBox>

                    <Label Content="Categoría:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbCategoria" Grid.Row="6" Grid.Column="1" Margin="5">
                        <ComboBoxItem Content="1 - Dirección" Tag="1"/>
                        <ComboBoxItem Content="2 - Jefe" Tag="2"/>
                        <ComboBoxItem Content="3 - Contable" Tag="3"/>
                        <ComboBoxItem Content="4 - Administrativo" Tag="4"/>
                        <ComboBoxItem Content="5 - Operativo" Tag="5"/>
                    </ComboBox>

                    <Label Content="Año de Ingreso:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtAñoIngreso" Grid.Row="7" Grid.Column="1" Margin="5"/>

                    <Label Content="Sector Asignado:" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtSectorAsignado" Grid.Row="8" Grid.Column="1" Margin="5"/>

                    <Label Content="Actividad:" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtActividad" Grid.Row="9" Grid.Column="1" Margin="5"/>

                    <Label Content="Sueldo Nominal:" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtSueldoNominal" Grid.Row="10" Grid.Column="1" Margin="5"/>
                </Grid>

                <!-- Botones de acción -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                    <Button x:Name="btnAgregar"
                            Content="Agregar"
                            Width="100"
                            Click="Agregar_Click"
                            Margin="5"/>
                    <Button Content="Editar Seleccionado"
                            Width="150"
                            Click="Editar_Click"
                            Margin="5"/>
                    <Button x:Name="btnCancelar"
                            Content="Cancelar Edición"
                            Width="130"
                            Click="Cancelar_Click"
                            Margin="5"
                            Visibility="Collapsed"/>
                    <Button Content="Eliminar Seleccionado"
                            Width="150"
                            Click="Eliminar_Click"
                            Margin="5"/>
                    <Button Content="Exportar CSV"
                            Width="110"
                            Click="Exportar_Click"
                            Margin="5"/>
                </StackPanel>

                <Separator Margin="0,20,0,20"/>

                <!-- Búsqueda -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Lista de Personal"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    <Label Content="Buscar:" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtBusqueda"
                             Width="280"
                             Margin="5,0"
                             VerticalAlignment="Center"
                             TextChanged="txtBusqueda_TextChanged"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="dataGridPersonal"
                          AutoGenerateColumns="False"
                          Height="300"
                          Margin="0,0,0,20"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding ApellidoNombre}" Width="*"/>
                        <DataGridTextColumn Header="Domicilio" Binding="{Binding Domicilio}" Width="*"/>
                        <DataGridTextColumn Header="Localidad" Binding="{Binding Localidad}" Width="*"/>
                        <DataGridTextColumn Header="Provincia" Binding="{Binding Provincia}" Width="*"/>
                        <DataGridTextColumn Header="Código Postal" Binding="{Binding CodigoPostal}" Width="*"/>
                        <DataGridTextColumn Header="Puesto" Binding="{Binding Puesto}" Width="*"/>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*"/>
                        <DataGridTextColumn Header="Año Ingreso" Binding="{Binding AñoIngreso}" Width="*"/>
                        <DataGridTextColumn Header="Sector Asignado" Binding="{Binding SectorAsignado}" Width="*"/>
                        <DataGridTextColumn Header="Actividad" Binding="{Binding Actividad}" Width="*"/>
                        <DataGridTextColumn Header="Sueldo Nominal" Binding="{Binding SueldoNominal}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
