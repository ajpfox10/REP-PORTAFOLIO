VITE_API_BASE_URL=http://192.168.0.21:3000/api/v1
VITE_AUTH_STORAGE=local
//memory (se borra al refresh)

//session (vive en pestaña)

//local (vive en el navegador)
# ─── MODO KIOSCO ──────────────────────────────────────────────────────────────
# Las PCs configuradas como kiosco solo muestran la página de Atención al Público.
# No pueden navegar a ninguna otra sección ni ver el menú.
#
# OPCIÓN A — IP fija (PC con IP estática o reserva DHCP en el router)
# VITE_KIOSK_IPS=192.168.0.50,192.168.0.51
VITE_KIOSK_IPS=
#
# OPCIÓN B — Nombre de PC (IP dinámica/DHCP)
# Requiere que la red tenga DNS con registros PTR (ej: Active Directory/WINS).
# VITE_KIOSK_HOSTNAMES=rrhh-entrada,rrhh-salida
VITE_KIOSK_HOSTNAMES=rrhh-entrada
#
# OPCIÓN C — Activación manual (funciona siempre, sin depender de IP ni DNS)
# Ir UNA SOLA VEZ desde el navegador de la PC kiosco a estas URLs:
#
#   ACTIVAR:    http://192.168.0.21:5173/set-kiosk
#   DESACTIVAR: http://192.168.0.21:5173/unset-kiosk
#
# El flag queda guardado en el localStorage del navegador de esa PC.
# Sobrevive reinicios y cambios de IP. Para borrar el kiosco hay que
# ir a /unset-kiosk o limpiar manualmente el localStorage del navegador.
VITE_KIOSK_ACTIVATE_URL=http://192.168.0.21:5173/set-kiosk
VITE_KIOSK_DEACTIVATE_URL=http://192.168.0.21:5173/unset-kiosk
# ──────────────────────────────────────────────────────────────────────────────
