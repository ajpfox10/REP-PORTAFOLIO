# ═══════════════════════════════════════════════════════════
# Scanner API v3 — .env
# Copiá esto como .env y completá los valores
# ═══════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# ── MySQL ─────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=scanner_saas
MYSQL_USER=root
MYSQL_PASSWORD=password

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Seguridad ─────────────────────────────────────────────
JWT_SECRET=cambia_esto_a_algo_muy_largo_y_secreto
JWT_TTL=8h
DEVICE_TOKEN_SECRET=cambia_esto_device_secret

# ── Storage ───────────────────────────────────────────────
STORAGE_PROVIDER=local          # local | s3 | minio
STORAGE_LOCAL_DIR=./storage
# STORAGE_S3_BUCKET=mi-bucket
# STORAGE_S3_ENDPOINT=http://minio:9000   # solo para MinIO

# ── Uploads ───────────────────────────────────────────────
MAX_UPLOAD_MB=150

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*    # En producción: https://tu-dominio.com

# ── OCR ───────────────────────────────────────────────────
OCR_PROVIDER=tesseract   # tesseract | none

# ── AI (opcional) ─────────────────────────────────────────
AI_PROVIDER=none          # none | openai
# OPENAI_API_KEY=sk-...

# ── Antivirus ─────────────────────────────────────────────
CLAMAV_ENABLED=false      # true en producción

# ── Auto-migración al iniciar ─────────────────────────────
AUTO_MIGRATE=true

# ── Integración con api_personal ─────────────────────────
# Se configura también por API: PUT /v1/integration
# PERSONAL_API_URL=http://localhost:3000
# PERSONAL_API_KEY=tu-api-key-del-backend-principal

# ═══════════════════════════════════════════════════════════
# Agent (.env del agente — en la PC del escáner)
# ═══════════════════════════════════════════════════════════
# BASE_URL=http://ip-del-servidor:3001
# AGENT_TENANT_ID=1
# AGENT_DEVICE_KEY=device_key_del_dispositivo
# SCAN_DRIVER=virtual   # virtual | wia | twain
# POLL_INTERVAL_MS=5000
# HEARTBEAT_MS=30000
