{
  "name": "scanner-saas",
  "private": true,
  "workspaces": [
    "api",
    "worker",
    "agent",
    "shared"
  ],
  "scripts": {
    "dev": "npm -w api run dev",
    "dev:worker": "npm -w worker run dev",
    "dev:agent": "npm -w agent run dev",
    "lint": "npm -ws run lint",
    "typecheck": "npm -ws run typecheck",
    "build": "npm -ws run build",
    "start": "npm -w api run start",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down -v"
  }
}
