# ═══════════════════════════════════════════════════════════
# Scanner API v3 — .env
# Mismo MySQL que api_personal, base de datos separada
# ═══════════════════════════════════════════════════════════

PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3002

# ── Mismo MySQL que api_personal ──────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=scanner_saas
MYSQL_USER=root
MYSQL_PASSWORD=Cuernos2503

# ── Redis (mismo que usa api_personal) ────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Seguridad ─────────────────────────────────────────────
JWT_SECRET=scanner_jwt_secret_cuernos2503
JWT_TTL=8h
# Secreto del api_personal para aceptar sus tokens directamente
# (mismo valor que JWT_ACCESS_SECRET en api_personal/.env)
PERSONAL_JWT_SECRET=supersecretaccesstoken1234567890

# ── Storage local ─────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./storage

MAX_UPLOAD_MB=150

# ── OCR: desactivado por defecto, activar cuando instales tesseract ──
OCR_PROVIDER=none
# OCR_PROVIDER=tesseract   <- activar después

# ── AI: clasificación por keywords, sin OpenAI ────────────
AI_PROVIDER=none

# ── Antivirus: desactivado (activar si tenés ClamAV) ─────
CLAMAV_ENABLED=false

# ── Crea las tablas automáticamente al iniciar ────────────
AUTO_MIGRATE=true

# ── Integración con api_personal ─────────────────────────
# (se configura por UI también: PUT /v1/integration)
PERSONAL_API_URL=http://localhost:3000
PERSONAL_API_KEY=pk_e86c326f6a372b4ed523f5566abaa9777c096d8c4b797ecb

# ── CORS: mismo origen que el front ──────────────────────
CORS_ORIGINS=http://localhost:5173,http://192.168.0.21:5173,http://localhost:3000,http://192.168.0.21:3000

RATE_LIMIT_MAX=5000
RATE_LIMIT_WINDOW_MS=60000

# Multi-Device Scanner Agent
BASE_URL=http://localhost:3001
AGENT_TENANT_ID=1
AGENT_EMAIL=admin@scanner.local
AGENT_PASSWORD=Admin1234
POLL_INTERVAL_MS=4000
HEARTBEAT_MS=30000