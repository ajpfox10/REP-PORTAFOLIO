# ═══════════════════════════════════════════════════════════
# Scanner Agent Lite — .env
# Copiar a .env y configurar
# ═══════════════════════════════════════════════════════════

# URL de la API del scanner (ajustar si prod: puerto 3002, dev: 3003)
BASE_URL=http://192.168.0.21:3003

# Tenant (siempre 1 en esta instalación)
AGENT_TENANT_ID=1

# Credenciales para autenticarse en la API
AGENT_EMAIL=admin@scanner.local
AGENT_PASSWORD=Admin1234

# Nombre de este agente (aparece como nombre del dispositivo)
# Si está vacío, usa el hostname de Windows
AGENT_NAME=

# Intervalo de polling en ms (default 4s)
POLL_INTERVAL_MS=4000
HEARTBEAT_MS=30000
