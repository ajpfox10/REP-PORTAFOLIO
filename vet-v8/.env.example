NODE_ENV=production
PORT=3000
TRUST_PROXY=1

MASTER_DB_HOST=localhost
MASTER_DB_PORT=3306
MASTER_DB_USER=vetpro_app
MASTER_DB_PASSWORD=CHANGE_ME_master_db_password_16chars
MASTER_DB_NAME=vetpro_master

TENANT_DB_HOST=localhost
TENANT_DB_PORT=3306
TENANT_DB_USER=vetpro_tenant
TENANT_DB_PASSWORD=CHANGE_ME_tenant_db_password_16chars

REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

JWT_ALGORITHM=RS256
JWT_KEY_ID=key-v1
JWT_SECRET=CHANGE_ME_only_for_dev_fallback_min_32_chars_xxxxxxxxxx
JWT_REFRESH_SECRET=CHANGE_ME_only_for_dev_refresh_min_32_chars_xxxxx
JWT_PRIVATE_KEY_PEM=
JWKS_PUBLIC_KEYS_JSON=[]

ENCRYPTION_MASTER_SECRET=CHANGE_ME_encryption_master_secret_32_chars_min
KMS_KEY_ID=

S3_REGION=sa-east-1
S3_BUCKET=vetpro-files-prod
SES_FROM_EMAIL=no-reply@vetpro.ar
SNS_REGION=sa-east-1
SNS_SENDER_ID=VetPro

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

INTERNAL_API_SHARED_SECRET=CHANGE_ME_internal_hmac_secret_32_chars_min
INTERNAL_API_IP_ALLOWLIST=10.0.0.10,10.0.0.11,127.0.0.1,::1
INTERNAL_API_NONCE_TTL_SECONDS=300
INTERNAL_API_REQUIRE_NONCE=true
INTERNAL_API_REQUIRE_PRIVATE_NETWORK=true

CORS_BASE_DOMAIN=vetpro.ar
CORS_ALLOWED_ORIGINS=https://vetpro.ar,https://admin.vetpro.ar,http://localhost:3000,http://localhost:5173
REQUIRE_CANONICAL_TENANT_HOST=true

METRICS_ENABLE=true
METRICS_PROTECT=true
METRICS_AUTH_TOKEN=CHANGE_ME_metrics_token_32_chars_minimum
METRICS_IP_ALLOWLIST=10.0.0.20,127.0.0.1,::1

AUTH_PASSWORD_MIN_LENGTH=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900
AUTH_REQUIRE_MFA_ON_RESET=true
AUTH_REQUIRE_STATEFUL_ACCESS_SESSION=true
AUTH_ENFORCE_SESSION_FINGERPRINT=true

FILES_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp
FILES_ALLOWED_PURPOSES=general,clinical,lab,invoice,profile
FILES_MAX_UPLOAD_BYTES=10485760
FILES_REQUIRE_SHA256=true

RLS_ALLOW_SHARED_ROWS=false

FF_ENABLE_BILLING=true
FF_ENABLE_PLUGINS=false
FF_ENABLE_FEATURE_FLAGS=true
FF_ENABLE_PLAN_LIMITS=true
FF_ENABLE_FILES=true

CRUD_STRICT_ALLOWLIST=true
CRUD_TABLE_ALLOWLIST=pacientes,propietarios,veterinarios,sucursales
CRUD_TABLE_DENYLIST=users,auditoria_log,migrations,schema_meta

OPENAPI_OUTPUT=docs/openapi.generated.yaml
SCHEMA_CACHE_TTL_SECONDS=300
TENANT_CONN_CACHE_TTL_SECONDS=600
