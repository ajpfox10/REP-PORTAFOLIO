NODE_ENV=development
PORT=3000
TRUST_PROXY=1

MASTER_DB_HOST=localhost
MASTER_DB_PORT=3306
MASTER_DB_USER=vetpro_app
MASTER_DB_PASSWORD=CHANGE_IN_PRODUCTION_MIN_16_CHARS
MASTER_DB_NAME=vetpro_master
MASTER_DB_ROOT_PASSWORD=CHANGE_IN_PRODUCTION_ROOT

TENANT_DB_HOST=localhost
TENANT_DB_PORT=3306
TENANT_DB_USER=vetpro_app
TENANT_DB_PASSWORD=CHANGE_IN_PRODUCTION_MIN_16_CHARS

REDIS_URL=redis://:CHANGE_IN_PRODUCTION@localhost:6379
REDIS_PASSWORD=CHANGE_IN_PRODUCTION

JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_STRING_32_CHARS
JWT_ALGORITHM=HS256
JWT_KEY_ID=key-v1

ENCRYPTION_MASTER_SECRET=CHANGE_THIS_TO_RANDOM_64_HEX_CHARS_openssl_rand_hex_32
KMS_KEY_ID=

STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=vetpro-files-prod
SES_FROM_EMAIL=noreply@tudominio.com
SNS_REGION=us-east-1
SNS_SENDER_ID=VetPro

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_TO_RANDOM_STRING

INTERNAL_API_IP_ALLOWLIST=127.0.0.1,::1
INTERNAL_API_SHARED_SECRET=CHANGE_TO_RANDOM_STRING_MIN_24_CHARS

FRONTEND_URL=https://app.vetpro.com

METRICS_ENABLE=true
METRICS_PROTECT=true
OTEL_EXPORTER_OTLP_ENDPOINT=

FEATURE_FLAGS={"FF_ENABLE_FILES":true}
SCHEMA_CACHE_TTL_SECONDS=300
TENANT_CONN_CACHE_TTL_SECONDS=600
CRUD_STRICT_ALLOWLIST=true
CRUD_TABLE_ALLOWLIST=pacientes,propietarios,veterinarios,productos,turnos,consultas
CRUD_TABLE_DENYLIST=users,auditoria_log
OPENAPI_OUTPUT=docs/openapi.json
