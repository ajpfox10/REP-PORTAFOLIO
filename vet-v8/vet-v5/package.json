{
  "name": "veterinaria-saas-platform",
  "version": "5.0.0",
  "description": "Multi-tenant SaaS platform for veterinary clinics",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "build":          "tsc",
    "dev":            "ts-node-dev --respawn --transpile-only src/index.ts",
    "start":          "node --enable-source-maps dist/index.js",
    "worker":         "node --enable-source-maps dist/worker/index.js",
    "worker:dev":     "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "test":           "jest --config jest.config.cjs",
    "test:unit":      "jest --config jest.config.cjs --testPathPattern=unit",
    "test:contract":  "jest --config jest.contract.config.cjs",
    "test:coverage":  "jest --config jest.config.cjs --coverage",
    "lint":           "tsc --noEmit",
    "health":         "curl -s http://localhost:3000/health | jq .",
    "migrate":        "ts-node src/migrations/runSqlMigrations.ts",
    "audit:verify":   "ts-node -e \"require('./src/scripts/auditVerify.ts')\"",
    "docker:build":   "docker build --target runtime -t vetpro-api:5.0.0 .",
    "docker:worker":  "docker build --target worker -t vetpro-worker:5.0.0 ."
  },
  "dependencies": {
    "@aws-sdk/client-s3":           "^3.0.0",
    "@aws-sdk/client-ses":          "^3.0.0",
    "@aws-sdk/client-sns":          "^3.0.0",
    "@aws-sdk/s3-request-presigner":"^3.0.0",
    "@opentelemetry/api":           "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/sdk-node":      "^0.55.0",
    "bcryptjs":                     "^2.4.3",
    "bullmq":                       "^5.0.0",
    "cors":                         "^2.8.5",
    "express":                      "^4.21.0",
    "express-prom-bundle":          "^7.0.0",
    "helmet":                       "^8.0.0",
    "ioredis":                      "^5.3.2",
    "jose":                         "^5.9.6",
    "mysql2":                       "^3.11.0",
    "nanoid":                       "^5.0.9",
    "otpauth":                      "^9.3.6",
    "pdfkit":                       "^0.15.1",
    "pino":                         "^9.5.0",
    "pino-http":                    "^10.3.0",
    "stripe":                       "^16.0.0",
    "zod":                          "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs":              "^2.4.6",
    "@types/cors":                  "^2.8.17",
    "@types/express":               "^5.0.0",
    "@types/jest":                  "^29.5.14",
    "@types/node":                  "^22.0.0",
    "@types/pdfkit":                "^0.13.0",
    "@types/pino":                  "^7.0.5",
    "jest":                         "^29.7.0",
    "ts-jest":                      "^29.2.5",
    "ts-node":                      "^10.9.2",
    "ts-node-dev":                  "^2.0.0",
    "typescript":                   "^5.6.3"
  }
}
